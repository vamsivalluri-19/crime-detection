# Copy this file to `.env` and fill in real values. Do NOT commit your `.env` file.

# MongoDB Connection URI
# Local development (runs by default if not set):
# mongodb://localhost:27017/crimeai
#
# Remote MongoDB Atlas example:
# mongodb+srv://username:password@cluster0.mongodb.net/crimeai?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/crimeai

# JWT Secret for authentication (change in production!)
JWT_SECRET=your_jwt_secret_change_this_in_production

# Server Port (optional, defaults to 3000)
PORT=3000

# API Base URL (optional)
API_BASE=http://localhost:3000
